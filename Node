package binarysearchtree;

/**
 *
 * @author dduncombe
 */
public class Node {
    
    Node left;
    Node right;
    Integer key;
    
    public Node(int key) {
        left = null;
        right = null;
        this.key = key;
    }
    
    public void setLeft(Node left) {
        this.left = left;
    }
    
    public Node getLeft() {
        return left;
    }
    
    public void setRight(Node right) {
        this.right = right;
    }
    
    public Node getRight() {
        return right;
    }
    
    public void setKey(int key) {
        this.key = key;
    }
    
    public int getKey() {
        return key;
    }
}
